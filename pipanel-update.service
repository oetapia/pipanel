[Unit]
Description=pipanel git update
After=network-online.target
Wants=network-online.target
Before=pipanel.service

[Service]
Type=oneshot
User=root
WorkingDirectory=/home/pi/pipanel
ExecStart=/bin/bash /home/pi/pipanel/update.sh
TimeoutStartSec=30
RemainAfterExit=no

[Install]
WantedBy=multi-user.target
